---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Projects from "../components/Projects.astro";
import Publications from "../components/Publications.astro";
---

<Layout title="Liuye Zhao - Academic Homepage">
	<Header />

	<main class="main-container">
		<div class="left-col">
			<Sidebar />
		</div>

		<div class="right-col">
			<About />
			<Experience />
			<Education />
			<Projects />
			<Publications />
		</div>
	</main>
</Layout>

<style>
	.main-container {
		max-width: 1280px; /* Increased to reduce side margins */
		margin: 1.5rem auto; /* Snug top/bottom margins */
		padding: 0 3rem; /* Slightly more inner padding if wider */
		display: grid;
		grid-template-columns: 220px 1fr; /* Snug sidebar width */
		gap: 2.25rem; /* Snug column gap */
	}

	@media (max-width: 768px) {
		.main-container {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}
</style>
