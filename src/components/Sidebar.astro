<aside class="sidebar">
	<!-- Avatar Crest Backdrop Wreath -->
	<div class="avatar-wrapper">
		<div class="avatar-crest-backdrop">
			<svg viewBox="0 0 200 200" class="crest-svg" xmlns="http://www.w3.org/2000/svg">
				<!-- Double circular boundaries for high-end academic crest feel -->
				<circle cx="100" cy="100" r="92" fill="none" stroke="rgba(30, 64, 175, 0.05)" stroke-width="1.2" />
				<circle cx="100" cy="100" r="86" fill="none" stroke="rgba(30, 64, 175, 0.08)" stroke-width="1.5" stroke-dasharray="3 3" />
				<circle cx="100" cy="100" r="70" fill="none" stroke="rgba(30, 64, 175, 0.06)" stroke-width="1" />
				
				<!-- Laurel Leaves Wreath Symmetrical Left Branch -->
				<path d="M 52,142 C 38,122 36,92 52,65" fill="none" stroke="rgba(30, 64, 175, 0.16)" stroke-width="1.5" />
				<circle cx="52" cy="142" r="1.5" fill="rgba(30, 64, 175, 0.2)" />
				<path d="M 46,131 C 40,129 40,121 48,123" fill="rgba(30, 64, 175, 0.15)" />
