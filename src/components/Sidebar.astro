				<path d="M 46,76 C 41,71 46,63 52,69" fill="rgba(30, 64, 175, 0.15)" />
				
				<!-- Laurel Leaves Wreath Symmetrical Right Branch -->
				<path d="M 148,142 C 162,122 164,92 148,65" fill="none" stroke="rgba(30, 64, 175, 0.16)" stroke-width="1.5" />
				<circle cx="148" cy="142" r="1.5" fill="rgba(30, 64, 175, 0.2)" />
				<path d="M 154,131 C 160,129 160,121 152,123" fill="rgba(30, 64, 175, 0.15)" />
				<path d="M 158,114 C 164,111 162,103 154,106" fill="rgba(30, 64, 175, 0.15)" />
				<path d="M 158,95 C 164,91 161,83 153,88" fill="rgba(30, 64, 175, 0.15)" />
				<path d="M 154,76 C 159,71 154,63 148,69" fill="rgba(30, 64, 175, 0.15)" />
			</svg>
		</div>
		<div class="photo-container">
			<img src="/me.jpg" alt="Liuye Zhao" class="photo" />
		</div>
		<!-- ZJU overlay badge bottom-right of avatar -->
		<div class="floating-badge-zju">
			<img src="/zju.png" alt="ZJU emblem" class="badge-zju-img" />
		</div>
	</div>

	<div class="info-container">
		<h1>Liuye Zhao</h1>
		<div class="name-spacer"></div>
		<p class="role">Undergraduate student</p>
		
		<div class="pill-boxes-group">
			<!-- Pill Box: Affiliation -->
			<div class="pill-box">
				<svg class="pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
					<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
				</svg>
				<span>@ Zhejiang University</span>
			</div>
			<!-- Pill Box: Email -->
			<div class="pill-box email-pill">
				<svg class="pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
					<polyline points="22,6 12,13 2,6" />
				</svg>
				<a href="mailto:masterforliage@gmail.com" class="email-link">masterforliage@gmail.com</a>
			</div>
		</div>

		<!-- Diamond Separator Side Column -->
		<div class="diamond-divider-sidebar">
			<div class="divider-line"></div>
			<div class="divider-diamond">
				<svg viewBox="0 0 100 100" class="diamond-svg">
					<polygon points="50,15 85,50 50,85 15,50" fill="#ffffff" stroke="#cbd5e1" stroke-width="8" />
					<polygon points="50,30 70,50 50,70 30,50" fill="#cbd5e1" />
				</svg>
			</div>
			<div class="divider-line"></div>
		</div>

		<div class="social-icons">
			<!-- Google Scholar -->
			<a href="#" aria-label="Google Scholar" class="icon-link scholar">
				<svg viewBox="0 0 512 512" class="icon">
