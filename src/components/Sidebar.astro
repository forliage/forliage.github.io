	<!-- Blueprint Campus Gate at bottom (Stunning high-fidelity vector of ZJU 求是门 Campus Gate) -->
	<div class="blueprint-gate">
		<svg viewBox="0 0 270 170" fill="none" stroke="rgba(37, 99, 235, 0.12)" stroke-width="1" xmlns="http://www.w3.org/2000/svg">
			<!-- Blueprint grid paper lines for blueprint/CAD look -->
			<line x1="0" y1="15" x2="270" y2="15" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="0" y1="35" x2="270" y2="35" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="0" y1="55" x2="270" y2="55" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="0" y1="75" x2="270" y2="75" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="0" y1="95" x2="270" y2="95" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="0" y1="115" x2="270" y2="115" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="0" y1="135" x2="270" y2="135" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="0" y1="155" x2="270" y2="155" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="35" y1="0" x2="35" y2="170" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="75" y1="0" x2="75" y2="170" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="115" y1="0" x2="115" y2="170" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="135" y1="0" x2="135" y2="170" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="155" y1="0" x2="155" y2="170" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="195" y1="0" x2="195" y2="170" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />
			<line x1="235" y1="0" x2="235" y2="170" stroke-dasharray="1 5" stroke-width="0.5" opacity="0.2" />

			<!-- Horizontal perspective ground steps -->
			<line x1="5" y1="150" x2="265" y2="150" stroke="rgba(37, 99, 235, 0.22)" stroke-width="1.2" />
			<line x1="10" y1="153" x2="260" y2="153" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />
			<line x1="18" y1="156" x2="252" y2="156" stroke="rgba(37, 99, 235, 0.1)" stroke-width="0.6" />

			<!-- Symmetrical road leading to distant building (Perspective) -->
			<line x1="110" y1="150" x2="128" y2="125" stroke="rgba(37, 99, 235, 0.1)" stroke-width="0.8" />
			<line x1="160" y1="150" x2="142" y2="125" stroke="rgba(37, 99, 235, 0.1)" stroke-width="0.8" />

			<!-- Distant background building outline -->
			<rect x="127" y="112" width="16" height="13" fill="#ffffff" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.6" />
			<polygon points="125,112 145,112 135,108" fill="#ffffff" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.6" />

			<!-- Left Side Tree Wreath Foliage (Pencil Sketch Look) -->
			<path d="M 5,145 C 5,110 45,110 40,145" fill="none" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.8" />
			<path d="M 12,138 C 12,100 48,100 44,138" fill="none" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.8" />
			<path d="M -2,150 C -2,118 28,118 24,150" fill="none" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.8" />
			<!-- Left side vertical tree trunks -->
			<line x1="18" y1="120" x2="18" y2="150" stroke="rgba(37, 99, 235, 0.06)" stroke-width="1" />
			<line x1="30" y1="125" x2="30" y2="150" stroke="rgba(37, 99, 235, 0.06)" stroke-width="1" />
			<line x1="8" y1="130" x2="8" y2="150" stroke="rgba(37, 99, 235, 0.04)" stroke-width="0.8" />

			<!-- Right Side Tree Wreath Foliage (Pencil Sketch Look) -->
			<path d="M 230,145 C 230,110 270,110 265,145" fill="none" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.8" />
			<path d="M 226,138 C 226,100 258,100 254,138" fill="none" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.8" />
			<path d="M 246,150 C 246,118 276,118 272,150" fill="none" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.8" />
			<!-- Right side vertical tree trunks -->
			<line x1="252" y1="120" x2="252" y2="150" stroke="rgba(37, 99, 235, 0.06)" stroke-width="1" />
			<line x1="240" y1="125" x2="240" y2="150" stroke="rgba(37, 99, 235, 0.06)" stroke-width="1" />
			<line x1="262" y1="130" x2="262" y2="150" stroke="rgba(37, 99, 235, 0.04)" stroke-width="0.8" />

			<!-- Outer Left Column (Classical Pedestal + Column Body) -->
			<rect x="52" y="122" width="12" height="28" rx="0.5" fill="#ffffff" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />
			<line x1="56" y1="122" x2="56" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<line x1="60" y1="122" x2="60" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<rect x="55" y="70" width="6" height="52" fill="#ffffff" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />
			<rect x="53" y="67" width="10" height="3" rx="0.5" fill="#ffffff" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />

			<!-- Inner Left Main Column -->
			<rect x="94" y="115" width="16" height="35" rx="1" fill="#ffffff" stroke="rgba(37, 99, 235, 0.18)" stroke-width="1" />
			<line x1="98" y1="115" x2="98" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<line x1="102" y1="115" x2="102" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<line x1="106" y1="115" x2="106" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<rect x="98" y="55" width="8" height="60" fill="#ffffff" stroke="rgba(37, 99, 235, 0.18)" stroke-width="1" />
			<rect x="95" y="51" width="14" height="4" rx="0.5" fill="#ffffff" stroke="rgba(37, 99, 235, 0.18)" stroke-width="1" />

			<!-- Inner Right Main Column -->
			<rect x="160" y="115" width="16" height="35" rx="1" fill="#ffffff" stroke="rgba(37, 99, 235, 0.18)" stroke-width="1" />
			<line x1="164" y1="115" x2="164" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<line x1="168" y1="115" x2="168" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<line x1="172" y1="115" x2="172" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<rect x="164" y="55" width="8" height="60" fill="#ffffff" stroke="rgba(37, 99, 235, 0.18)" stroke-width="1" />
			<rect x="161" y="51" width="14" height="4" rx="0.5" fill="#ffffff" stroke="rgba(37, 99, 235, 0.18)" stroke-width="1" />

			<!-- Outer Right Column -->
			<rect x="206" y="122" width="12" height="28" rx="0.5" fill="#ffffff" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />
			<line x1="210" y1="122" x2="210" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<line x1="214" y1="122" x2="214" y2="150" stroke="rgba(37, 99, 235, 0.08)" stroke-width="0.5" />
			<rect x="209" y="70" width="6" height="52" fill="#ffffff" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />
			<rect x="207" y="67" width="10" height="3" rx="0.5" fill="#ffffff" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />

			<!-- Beams & Lintel (Horizontal architraves) -->
			<!-- Center Arch Lintel with Calligraphy -->
			<rect x="106" y="56" width="58" height="15" fill="#ffffff" stroke="rgba(37, 99, 235, 0.2)" stroke-width="1.2" />
			<!-- High-end elegant Serif text for ZJU campus gate name -->
			<text x="135" y="66" font-family="'Source Serif 4', 'Noto Serif CJK SC', 'SimSun', serif" font-size="7.5" font-weight="900" fill="rgba(30, 64, 175, 0.45)" text-anchor="middle" letter-spacing="2">浙江大学</text>

			<!-- Left Side Arch Lintel -->
			<rect x="61" y="72" width="37" height="10" fill="#ffffff" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />
			<!-- Right Side Arch Lintel -->
			<rect x="172" y="72" width="37" height="10" fill="#ffffff" stroke="rgba(37, 99, 235, 0.15)" stroke-width="0.8" />

			<!-- Traditional Chinese Architecture Roofs (Curved upturned corners) -->
			<!-- Left Roof Eave -->
			<path d="M 48,68 C 62,65 92,65 106,68 C 109,66 110,63 107,62 C 92,59 62,59 47,62 C 44,63 45,66 48,68 Z" fill="#ffffff" stroke="rgba(37, 99, 235, 0.18)" stroke-width="0.8" />
			<!-- Right Roof Eave -->
			<path d="M 164,68 C 178,65 208,65 222,68 C 225,66 226,63 223,62 C 208,59 178,59 163,62 C 160,63 161,66 164,68 Z" fill="#ffffff" stroke="rgba(37, 99, 235, 0.18)" stroke-width="0.8" />

			<!-- Main Central Double-Eaved Roof -->
			<!-- Lower Main Curved Eave -->
			<path d="M 88,51 C 110,47 160,47 182,51 C 187,49 189,45 184,43 C 160,39 110,39 86,43 C 81,45 83,49 88,51 Z" fill="#ffffff" stroke="rgba(37, 99, 235, 0.22)" stroke-width="1" />
			<!-- Upper Main Curved Eave -->
			<path d="M 98,40 C 115,36 155,36 172,40 C 176,38 177,34 173,33 C 155,30 115,30 97,33 C 93,34 94,38 98,40 Z" fill="#ffffff" stroke="rgba(37, 99, 235, 0.22)" stroke-width="1" />
			<!-- Top Main curved ridge -->
			<path d="M 108,31 Q 135,29 162,31 L 160,28 Q 135,26 110,28 Z" fill="#ffffff" stroke="rgba(37, 99, 235, 0.2)" stroke-width="0.8" />
			<circle cx="135" cy="27" r="1.5" stroke="rgba(37, 99, 235, 0.2)" stroke-width="0.8" />
		</svg>
	</div>
</aside>

<style>
	.sidebar {
		background: #ffffff;
		padding: 1.75rem 1rem 170px 1rem; /* 170px bottom padding creates a dedicated spacious zone for the ZJU blueprint gate */
		border-radius: 16px;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
		border: 1px solid #e2e8f0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem; /* Tightened from 1.25rem */
		height: fit-content;
		text-align: center;
		position: relative;
		overflow: hidden; /* To clip bottom blueprint-gate */
	}

	.avatar-wrapper {
		position: relative;
		width: 170px;
		height: 170px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.avatar-crest-backdrop {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
	}

	.crest-svg {
		width: 100%;
		height: 100%;
	}

	.photo-container {
		width: 110px;
		height: 110px;
		border-radius: 50%;
		overflow: hidden;
		border: 4px solid #ffffff;
		box-shadow: 0 4px 15px rgba(30, 64, 175, 0.15); /* Blue-tint shadow */
		z-index: 2;
	}

	.photo {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Floating circular ZJU Badge overlay bottom-right of avatar */
	.floating-badge-zju {
		position: absolute;
		bottom: 24px;
		right: 24px;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: #ffffff;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
		border: 2px solid #ffffff;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 3;
	}

	.badge-zju-img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.info-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.35rem; /* Tightened from 0.5rem */
		width: 100%;
		z-index: 2;
	}

