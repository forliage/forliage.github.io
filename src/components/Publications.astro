---
interface Publication {
	title: string;
	venue?: string;
	authors?: string[];
	links?: { text: string; url: string }[];
}

const publications: Publication[] = [
	//{
	//	title: "Lightweight, Edge-Aware, and Temporally Consistent Supersampling for Mobile Real-Time Rendering",
	//	venue: "ACM Transactions on Graphics (conditionally accepted, 2025)",
	//	authors: ["Sipeng Yang", "Jiayu Ji", "Junhao Zhuge", "Hezhu Zhang", "Qiang Qiu", "Chen Li", "Yuzhong Yan", "Kerong Wang", "Ling-Qi Yan", "Xiaogang Jin*"],
	//	links: [
	//		{ text: "PDF", url: "#" },
	//		{ text: "Code", url: "#" }
	//	]
	//}
	{ title: "Coming soon" },
];
---

<section id="publications" class="publications">
	<h1 class="section-title">
		<span class="title-icon-wrapper">
			<svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
				<polyline points="14 2 14 8 20 8" />
				<line x1="16" y1="13" x2="8" y2="13" />
				<line x1="16" y1="17" x2="8" y2="17" />
				<polyline points="10 9 9 9 8 9" />
			</svg>
		</span>
		Selected Publications
	</h1>

	<div class="pub-list">
		{
			publications.map((pub) => (
				<div class="pub-item">
					<h3 class="pub-title">
						<a href="#">{pub.title}</a>
					</h3>
					<div class="pub-venue">{pub.venue}</div>
					<div class="pub-authors">
						{pub.authors?.map((author, index) => (
							<span>
								{author.includes("Liuye Zhao") ? (
									<strong>{author}</strong>
								) : (
									author
								)}
								{pub.authors && index < pub.authors.length - 1
									? ", "
									: ""}
							</span>
						))}
					</div>
					<div class="pub-links">
						{pub.links &&
							pub.links.map((link) => (
								<a href={link.url} class="link-btn">
									[{link.text}]
								</a>
							))}
					</div>
				</div>
			))
		}
	</div>
</section>

<style>
	.publications {
		background: #ffffff;
		padding: 1.5rem 2rem;
		border-radius: 16px;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
		border: 1px solid #e2e8f0;
	}

	.section-title {
		font-size: 1.5rem;
		font-weight: 700;
		color: #0f172a;
		display: flex;
		align-items: center;
		gap: 0.65rem;
		border-bottom: 2px solid #e2e8f0;
		padding-bottom: 0.65rem;
		margin-bottom: 1.25rem;
	}

	.title-icon-wrapper {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border: 1.5px solid #1e40af;
		border-radius: 50%;
		background: #eff6ff;
		color: #1e40af;
		flex-shrink: 0;
	}

	.title-icon {
		width: 16px;
		height: 16px;
	}

	.pub-item {
		margin-bottom: 1.25rem; /* Compact margin */
		padding-bottom: 1rem; /* Compact padding */
		border-bottom: 1px dashed #eee;
	}

	.pub-item:last-child {
		border-bottom: none;
	}

	.pub-title {
		font-size: 1.2rem;
		margin-bottom: 0.25rem;
	}

	.pub-title a {
		color: var(--color-primary);
		font-family: "Source Serif 4", serif;
		font-weight: 400;
		font-size: 1.1rem; /* Explicit size, slightly smaller than default h3 */
	}

	.pub-venue {
		font-style: italic;
		color: #666;
		margin-bottom: 0.25rem;
		font-family: "Source Serif 4", serif;
		font-size: 0.85rem; /* Body text smaller */
	}

	.pub-authors {
		color: #444;
		margin-bottom: 0.5rem;
		font-family: "Source Serif 4", serif;
		font-size: 0.85rem; /* Body text smaller */
	}

	.link-btn {
		font-size: 0.9rem;
		margin-right: 0.5rem;
		font-weight: 600;
	}
</style>
